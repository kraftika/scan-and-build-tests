// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`writeSpecFile > snapshot: output is stable 1`] = `
"import { test, expect } from '@playwright/test';

test.describe('https://example.com/dashboard', () => {
  test('page loads without errors', async ({ page }) => {
    const consoleErrors: string[] = [];
    page.on('console', (msg) => {
      if (msg.type() === 'error') consoleErrors.push(msg.text());
    });
    await page.goto('https://example.com/dashboard');
    await expect(page.locator('body')).toBeVisible();
    expect(consoleErrors).toHaveLength(0);
  });

  test('clicking Settings navigates to settings page', async ({ page }) => {
    await page.goto('https://example.com/dashboard');
    await page.locator('a[href="/settings"]').first().click();
    await expect(page).toHaveURL(/URL contains \\/settings/);
  });

  test('login form submits with valid credentials', async ({ page }) => {
    await page.goto('https://example.com/dashboard');
    const form = page.locator('form').first();
    await form.locator('input[type="text"], input[type="email"], input:not([type])').first().fill('test@example.com');
    await form.locator('button[type="submit"], input[type="submit"], button').last().click();
    await page.waitForLoadState('networkidle');
    await expect(page.locator('body')).toBeVisible();
  });

  test('Create button opens modal', async ({ page }) => {
    await page.goto('https://example.com/dashboard');
    await page.locator('button:has-text("Create")').first().click();
    await expect(page.locator('body')).toBeVisible();
  });
});
"
`;
